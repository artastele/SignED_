# SignED SPED System - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# Application Settings
APP_NAME=SignED
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/SignED_

# Database Configuration
DB_HOST=localhost
DB_NAME=signed_system
DB_USER=root
DB_PASS=

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@signed.local
SMTP_FROM_NAME=SignED System

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost/SignED_/auth/googleCallback

# Security Settings
SESSION_LIFETIME=3600
SESSION_TIMEOUT=900
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=1800

# File Upload Settings
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx

# Encryption
ENCRYPTION_KEY=
